import tkinter as tk

window = tk.Tk()
window.title("CGP Assignment - Canvas Drawing")
window.geometry("500x400")

canvas = tk.Canvas(window, width=500, height=400, bg="white")
canvas.pack()


canvas.create_rectangle(50, 50, 150, 150, fill="maroon")

canvas.create_oval(200, 50, 350, 150, fill="green")

canvas.create_line(50, 200, 300, 200, fill="red", width=3)

canvas.create_text(250, 350, text="Sangullas, Lemuel", font=("Arial", 8, "bold"))

# Run the window
window.mainloop()
  
